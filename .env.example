# Debug / local template
# Android emulator → host machine proxy:
API_BASE_URL=http://10.0.2.2:8080/v1
# iOS simulator (Environment rewrites 10.0.2.2 → 127.0.0.1 automatically):
# API_BASE_URL=http://127.0.0.1:8080/v1

# Optional: call Supercell directly (no proxy). Prefer api/ proxy instead.
# COC_KEY=your_local_supercell_api_key_here

# Release uses `.env.production` (Cloud Run). Debug uses `.env.development`.
